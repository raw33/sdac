# Database (Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/sdac?schema=public"

# Auth (required)
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# If you deploy the app at app.sdak.org and the marketing site at sdak.org,
# set these to your app domain so marketing pages can link users into the app.
APP_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_BASE_URL="http://localhost:3000"

# Root domain for paid org subdomains like brown.sdak.org
CUSTOM_DOMAIN_ROOT="sdak.org"

# Optional SSO login (Google)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Analytics privacy (recommended)
IP_HASH_SALT="replace-with-a-long-random-secret"

# Used for QR code generation (optional but recommended in production)
# If your public short links live on sdak.org, set this to https://sdak.org
PUBLIC_BASE_URL="https://sdak.org"

# Billing (Stripe) — required if you enable /app/billing
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""

# Seed defaults (optional)
ADMIN_EMAIL="admin@sdac.org"
ADMIN_PASSWORD="ChangeMe123!"
ORG_NAME="SDAC"
ORG_SLUG="sdac"

# Comma-separated superusers (top-level admin access)
SUPERUSER_EMAILS="richward33@gmail.com"
